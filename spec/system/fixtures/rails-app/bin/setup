#!/bin/sh
# Prepares the dummy Rails app: waits for postgres, creates the role,
# database, and schema, and verifies redis. Expects DATABASE_URL and
# REDIS_URL. Idempotent. Runs as root inside the sandbox; database
# administration happens as the postgres system user.
set -eu
cd "$(dirname "$0")/.."

for _ in $(seq 1 30); do
    pg_isready -q -h 127.0.0.1 -p 5432 && break
    sleep 1
done
pg_isready -q -h 127.0.0.1 -p 5432

as_postgres() {
    su -s /bin/sh postgres -c "$1"
}

as_postgres "psql -tAc \"SELECT 1 FROM pg_roles WHERE rolname = 'rails'\"" | grep -q 1 \
    || as_postgres "psql -c \"CREATE ROLE rails LOGIN PASSWORD 'railspw'\""
as_postgres "psql -tAc \"SELECT 1 FROM pg_database WHERE datname = 'rails_dummy_development'\"" | grep -q 1 \
    || as_postgres "createdb -O rails rails_dummy_development"

psql "$DATABASE_URL" -q -f db/schema.sql
redis-cli -u "$REDIS_URL" ping > /dev/null

echo "dummy rails app ready"
