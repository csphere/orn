#!/usr/bin/env ruby
# frozen_string_literal: true

# Fast path: per-keystroke shell completion runs `orn complete` constantly, so
# short-circuit it here with a minimal require rather than loading Thor, the
# TUI, detection, and the sandbox layer.
if ARGV.first == "complete"
  require_relative "../lib/orn/complete"
  Orn::Complete.print_candidates
  exit 0
end

require "orn"

begin
  Orn::Shim.new(ARGV.dup).run
rescue Orn::Error => e
  warn "orn: #{e.message}"
  exit 1
end
